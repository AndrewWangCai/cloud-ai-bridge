# Conduit 运行环境（复制到 /opt/ai-sandbox/secrets/conduit.env，按需修改，权限设 600）
# chmod 600 /opt/ai-sandbox/secrets/conduit.env

# 监听端口（Nginx/Caddy 反代到这里）
PORT=8080
# 前面有 HTTPS 反代时置 1，让会话 cookie 带 Secure
COOKIE_SECURE=1

# 管理员用户名（逗号分隔），决定谁能进 /admin.html
ADMIN_USERS=admin

# 注册与门禁（现注册走「邮箱激活码」，开放注册；INVITE_REQUIRED 已弃用，保留兼容）
REGISTRATION_ENABLED=1
PROJECT_CREATION_ENABLED=1
FREE_TIER_ENABLED=1
# 每 IP 每天注册上限（风控）
MAX_REGISTER_PER_IP_PER_DAY=3

# 邮箱激活码发送（SMTP）。未配置则注册无法发码（dev 模式会把码打到控制台）。
# QQ/163/Gmail：到邮箱设置开启 SMTP，用「应用专用密码」作为 SMTP_PASS。
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=you@qq.com
SMTP_PASS=替换为应用专用密码
SMTP_FROM=you@qq.com
MAIL_APP_NAME=Cloud AI Bridge
# 激活码有效期/重发间隔（毫秒）
ACTIVATION_TTL_MS=900000
RESEND_INTERVAL_MS=60000

# GitHub OAuth 一键（连接/建仓/开 PR）。需在 GitHub 注册一个 OAuth App：
#   GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#   Homepage URL = https://你的域名
#   Authorization callback URL = https://你的域名/api/github/oauth/callback
# 不填则该功能自动隐藏（用户仍可用手动 Git 命令）。
PUBLIC_BASE_URL=https://你的域名
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CALLBACK=  # 一般留空，自动用 PUBLIC_BASE_URL 拼出；特殊情况可显式指定
GITHUB_OAUTH_SCOPE=repo

# 生命周期与配额
FREE_RUN_DAYS=5
# 公开测试建议 48 小时：设 FREE_RUN_HOURS=48 会覆盖上面的天数（>0 生效）
FREE_RUN_HOURS=0
RETENTION_DAYS=10
MAX_RUNNING_FREE=1
MAX_CREATE_PER_DAY=1
CLEANUP_INTERVAL_MS=300000

# 预览链接
PREVIEW_TTL_MIN=30
MAX_PREVIEW_PER_PROJECT=3

# Docker 与目录（对齐 /opt/ai-sandbox 标准目录）
SANDBOX_NETWORK=ai-sandbox-net
AI_SANDBOX_WORKSPACE_BASE=/opt/ai-sandbox/workspaces
AI_SANDBOX_BACKUP_BASE=/opt/ai-sandbox/backups
AI_SANDBOX_DATA_DIR=/opt/ai-sandbox/data
AI_SANDBOX_COMMUNITY_DIR=/opt/ai-sandbox/community
